# ═══════════════════════════════════════════════════════════════════════════════
# CARVanta Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Environment ──────────────────────────────────────────────────────────────
# Options: development, staging, production
ENVIRONMENT=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Local SQLite (default for development):
DATABASE_URL=sqlite:///data/carvanta.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@host:5432/carvanta

# ─── API Server ───────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8001
# Comma-separated CORS origins (* for development, restrict in production)
CORS_ORIGINS=*

# ─── API Keys ────────────────────────────────────────────────────────────────
# Generate unique keys for each tier. These are the RAW key strings
# that clients send in the X-CARVanta-API-Key header.
# Leave blank to disable API key enforcement.
CARVANTA_API_KEY_DEV=
CARVANTA_API_KEY_PRO=
CARVANTA_API_KEY_ENTERPRISE=

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=10

# ─── External Data APIs ──────────────────────────────────────────────────────
TCGA_GDC_BASE_URL=https://api.gdc.cancer.gov
GTEX_API_BASE_URL=https://gtexportal.org/api/v2
HPA_API_BASE_URL=https://www.proteinatlas.org
UNIPROT_API_BASE_URL=https://rest.uniprot.org
CLINICAL_TRIALS_API_URL=https://clinicaltrials.gov/api/v2

# ─── Data Pipeline ───────────────────────────────────────────────────────────
CACHE_MAX_AGE_DAYS=30
API_REQUEST_TIMEOUT=30
API_RATE_LIMIT_DELAY=0.5

# ─── ML / GNN ────────────────────────────────────────────────────────────────
GNN_ENABLED=false
GENE_TARGET_COUNT=16000
RANDOM_SEED=42
